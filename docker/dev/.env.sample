# GITHUB_OWNER
# - CI/CD: GitHub Actions가 github.repository_owner 변수로 자동 주입 (별도 설정 불필요)
# - 로컬에서 직접 docker compose를 실행할 경우에만 직접 입력
GITHUB_OWNER=your-github-username

# DB 접속 정보
# - CI/CD: GitHub Actions environment(dev) 시크릿 DB_USERNAME / DB_PASSWORD 로 자동 주입
# - 로컬에서 직접 docker compose를 실행할 경우에만 직접 입력
DB_USERNAME=pigeon
DB_PASSWORD=change-me

# Sentry DSN
# - CI/CD: GitHub Actions environment(dev) 시크릿 SENTRY_DSN 으로 자동 주입
# - 로컬에서 직접 docker compose를 실행할 경우에만 직접 입력
# - 비워두면 Sentry 비활성
SENTRY_DSN=
